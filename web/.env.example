# Copy to .env.local — never commit secrets

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Server-only auth admin (Stage 3: account deletion, Stripe webhook side effects)
SUPABASE_SERVICE_ROLE_KEY=

# Public site URL (Stripe redirects, portal return)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: AI name extraction + reply generation (mock/fallback if unset)
OPENAI_API_KEY=

# Free tier monthly generations (also NEXT_PUBLIC_FREE_GENERATIONS_PER_MONTH for client hints)
# NEXT_PUBLIC_FREE_GENERATIONS_PER_MONTH=20
# PRO_MONTHLY_GENERATIONS=600
# FREE_MAX_CONTACTS=8

# Stripe (Stage 3)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRO=

# API rate limit per user per hour (single-node in-memory; raise for local dev)
# API_RATE_LIMIT_PER_HOUR=80
